-- Сервисы Roblox
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local CoreGui = game:GetService("CoreGui")
local LocalPlayer = Players.LocalPlayer

-- Флаг состояния флинга
_G.FlingEnabled = false
local heartbeatConnection = nil

-- Функция включения/выключения физики флинга
local function toggleFling(state)
    _G.FlingEnabled = state
    
    local character = LocalPlayer.Character
    local rootPart = character and character:FindFirstChild("HumanoidRootPart")
    
    if not state then
        -- Отключаем: убираем скорость и соединение
        if heartbeatConnection then heartbeatConnection:Disconnect() end
        if rootPart and rootPart:FindFirstChild("FlingVelocity") then
            rootPart.FlingVelocity:Destroy()
        end
        return
    end
    
    -- Включаем: создаем вращение
    if character and rootPart then
        if not rootPart:FindFirstChild("FlingVelocity") then
            local bodyVelocity = Instance.new("BodyAngularVelocity")
            bodyVelocity.Name = "FlingVelocity"
            bodyVelocity.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
            bodyVelocity.AngularVelocity = Vector3.new(0, 99999, 0)
            bodyVelocity.Parent = rootPart
        end
        
        -- Постоянный цикл для отключения коллизии
        if heartbeatConnection then heartbeatConnection:Disconnect() end
        heartbeatConnection = RunService.Heartbeat:Connect(function()
            local currentCharacter = LocalPlayer.Character
            if not currentCharacter or not _G.FlingEnabled then return end
            
            for _, part in ipairs(currentCharacter:GetChildren()) do
                if part:IsA("BasePart") then
                    part.CanCollide = false
                    part.Velocity = Vector3.new(0, 25, 0)
                end
            end
        end)
    end
end

