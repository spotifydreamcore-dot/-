-- Сервисы Roblox
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local CoreGui = game:GetService("CoreGui")
local LocalPlayer = Players.LocalPlayer

_G.FlingEnabled = false
local heartbeatConnection = nil

-- Функция для безопасного и мощного флинга
local function toggleFling(state)
    _G.FlingEnabled = state
    
    local character = LocalPlayer.Character
    local rootPart = character and character:FindFirstChild("HumanoidRootPart")
    local humanoid = character and character:FindFirstChildOfClass("Humanoid")
    
    if not state then
        if heartbeatConnection then heartbeatConnection:Disconnect() end
        if rootPart then
            for _, v in ipairs(rootPart:GetChildren()) do
                if v.Name == "StableFling" or v.Name == "FlingForce" then v:Destroy() end
            end
        end
        return
    end
    
    if character and rootPart and humanoid then
        -- Настройка физики вращения (используем более стабильный вектор)
        local bg = Instance.new("BodyAngularVelocity")
        bg.Name = "FlingForce"
        bg.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
        bg.AngularVelocity = Vector3.new(0, 999999, 0) -- Экстремальная скорость
        bg.Parent = rootPart
        
        -- Фиксатор высоты (чтобы не улетать вверх/вниз)
        local bp = Instance.new("BodyPosition")
        bp.Name = "StableFling"
        bp.MaxForce = Vector3.new(0, math.huge, 0) -- Держит только высоту
        bp.Position = Vector3.new(0, rootPart.Position.Y, 0)
        bp.Parent = rootPart

        -- Запоминаем стартовую высоту перед включением
        local startY = rootPart.Position.Y

        if heartbeatConnection then heartbeatConnection:Disconnect() end
        heartbeatConnection = RunService.Heartbeat:Connect(function()
            local curChar = LocalPlayer.Character
            local curRoot = curChar tactics and curChar:FindFirstChild("HumanoidRootPart")
            
            if not curChar or not curRoot or not _G.FlingEnabled then return end
            
            -- Обновляем стабильную высоту по ходу движения (чтобы можно было ходить по лестницам)
            if humanoid.MoveDirection.Magnitude > 0 then
                bp.Position = Vector3.new(0, curRoot.Position.Y, 0)
            else
                bp.Position = Vector3.new(0, startY, 0)
            end

            -- Ломаем коллизию персонажа, КРОМЕ возможности ходить по земле
            for _, part in ipairs(curChar:GetChildren()) do
                if part:IsA("BasePart") then
                    part.CanCollide = false
                    -- Создаем "агрессивную" физику для передачи импульса другим игрокам
                    part.Velocity = Vector3.new(randomVelocity(), 0, randomVelocity())
                end
            end
            
            -- Принудительно забираем Network Ownership на хитбоксы врагов рядом
            for _, player in ipairs(Players:GetPlayers()) do
                if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                    local enemyRoot = player.Character.HumanoidRootPart
                    local distance = (curRoot.Position - enemyRoot.Position).Magnitude
                    
                    -- Если враг близко, создаем микро-толчок в его сторону на уровне сетевого кода
                    if distance < 8 then
                        curRoot.Velocity = (enemyRoot.Position - curRoot.Position).Unit * 45
                    end
                end
            end
        end)
    end
end

-- Вспомогательная функция для дестабилизации физики цели
function randomVelocity()
    return math.random(1, 2) == 1 and 35 or -35
end

