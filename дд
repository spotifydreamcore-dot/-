ToggleButton.Position = UDim2.new(0.5, -90, 0.5, -5)
ToggleButton.BackgroundColor3 = Color3.fromRGB(180, 40, 40) -- Красный (выключено)
ToggleButton.Text = "FLING: OFF"
ToggleButton.TextColor3 = Color3.fromRGB(255, 255, 255)
ToggleButton.TextSize = 18
ToggleButton.Font = Enum.Font.SourceSansBold
ToggleButton.Parent = MainFrame

local ButtonCorner = Instance.new("UICorner")
ButtonCorner.CornerRadius = UDim.new(0, 6)
ButtonCorner.Parent = ToggleButton

-- Логика клика по кнопке
ToggleButton.MouseButton1Click:Connect(function()
    if _G.FlingEnabled then
        toggleFling(false)
        ToggleButton.Text = "FLING: OFF"
        ToggleButton.BackgroundColor3 = Color3.fromRGB(180, 40, 40)
    else
        toggleFling(true)
        ToggleButton.Text = "FLING: ON"
        ToggleButton.BackgroundColor3 = Color3.fromRGB(40, 180, 40) -- Зеленый (включено)
    end
end)

-- Авто-перезапуск логики флинга при респавне (если кнопка была активна)
LocalPlayer.CharacterAdded:Connect(function()
    if _G.FlingEnabled then
        task.wait(0.5)
        toggleFling(true)
    end
end)
