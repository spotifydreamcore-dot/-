-- Сервисы Roblox
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local PlayerGui = game:GetService("Players").LocalPlayer:WaitForChild("PlayerGui")
local Camera = workspace.CurrentCamera
local LocalPlayer = Players.LocalPlayer

_G.MobileNoclip = false
local noclipConnection = nil
local flyConnection = nil

local FLY_SPEED = 40 -- Оптимальная скорость для мобилок

-- Переменные для вертикального полета
local moveUp = false
local moveDown = false

-- Функция работы Noclip + Fly
local function toggleMobileNoclip(state)
    _G.MobileNoclip = state
    local character = LocalPlayer.Character
    local humanoid = character Tactics and character:FindFirstChildOfClass("Humanoid")
    local rootPart = character and character:FindFirstChild("HumanoidRootPart")
    
    if not state then
        if noclipConnection then noclipConnection:Disconnect() end
        if flyConnection then flyConnection:Disconnect() end
        if humanoid then humanoid.PlatformStand = false end
        if rootPart then rootPart.Velocity = Vector3.new(0, 0, 0) end
        return
    end
    
    if character and humanoid and rootPart then
        humanoid.PlatformStand = true
        
        -- Коллизия стен (Stepped для защиты от багов)
        if noclipConnection then noclipConnection:Disconnect() end
        noclipConnection = RunService.Stepped:Connect(function()
            if not _G.MobileNoclip or not LocalPlayer.Character then return end
            for _, part in ipairs(LocalPlayer.Character:GetChildren()) do
                if part:IsA("BasePart") then
                    part.CanCollide = false
                end
            end
        end)
        
        -- Полет по направлению мобильного джойстика
        if flyConnection then flyConnection:Disconnect() end
        flyConnection = RunService.RenderStepped:Connect(function()
            local curChar = LocalPlayer.Character
            local curRoot = curChar and curChar:FindFirstChild("HumanoidRootPart")
            local curHum = curChar and curChar:FindFirstChildOfClass("Humanoid")
            
            if not curChar or not curRoot or not _G.MobileNoclip then return end
            curHum.PlatformStand = true
            
            -- Получаем вектор движения от мобильного джойстика игрока
            local moveDirection = curHum.MoveDirection
            local velocityVector = moveDirection * FLY_SPEED
            
            -- Добавляем вертикальное движение от созданных кнопок
            local verticalSpeed = 0
            if moveUp then
                verticalSpeed = FLY_SPEED
            elseif moveDown then
                verticalSpeed = -FLY_SPEED
            end
            
            curRoot.Velocity = Vector3.new(velocityVector.X, verticalSpeed ~= 0 and verticalSpeed or curRoot.Velocity.Y, velocityVector.Z)
            
            -- Если джойстик и кнопки не трогаются — намертво зависаем в воздухе
            if moveDirection.Magnitude == 0 and not moveUp and not moveDown then
                curRoot.Velocity = Vector3.new(0, 0, 0)
            end
        end)
    end
end

